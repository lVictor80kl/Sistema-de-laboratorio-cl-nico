{
  "name": "matrix-agent-chat",
  "displayName": "Matrix Agent Chat",
  "description": "Chat con Matrix Agent directamente desde tu editor - panel lateral estilo Copilot",
  "version": "1.0.0",
  "publisher": "matrix-agent",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:matrixAgentChat.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "matrixAgentChat.open",
        "title": "Abrir Matrix Agent Chat",
        "category": "Matrix Agent",
        "icon": "$(chat)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "matrixAgentChatSidebar",
          "title": "Matrix Agent",
          "icon": "$(chat)"
        }
      ]
    },
    "views": {
      "matrixAgentChatSidebar": [
        {
          "id": "matrixAgentChatView",
          "name": "Chat"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "matrixAgentChat.open",
          "when": "view == matrixAgentChatView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "cd .. && npm install && cd out && cd .. && npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0"
  }
}
